APP_NAME=FaceR Document Validation API
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
PORT=8080
AUTH_API_KEY=change-me-local

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zona_franca_backend
DB_USER=root
DB_PASSWORD=root
DB_SOCKET_DIR=/cloudsql
CLOUD_SQL_CONNECTION_NAME=
INSTANCE_CONNECTION_NAME=
DATABASE_URL=sqlite:///./local_dev.db

GCP_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_DOCUMENTS_PREFIX=documents
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=local_storage
PADDLE_HOME_DIR=.paddle
PADDLEOCR_HOME_DIR=.paddleocr
PADDLEOCR_LANG=es
PADDLEOCR_USE_ANGLE_CLS=true
PADDLEOCR_USE_GPU=false
PADDLEOCR_SHOW_LOG=false
PADDLEOCR_DET_LIMIT_SIDE_LEN=1920
PADDLEOCR_DROP_SCORE=0.35
PADDLEOCR_DET_DB_BOX_THRESH=0.35
PADDLEOCR_DET_DB_THRESH=0.25
DOCUMENT_AUTO_CROP=true
PREPROCESS_CLAHE_CLIP_LIMIT=2.2
PREPROCESS_ADAPTIVE_BLOCK_SIZE=31
PREPROCESS_ADAPTIVE_C=15
PREPROCESS_SHARPEN_STRENGTH=1.35

MAX_UPLOAD_SIZE_BYTES=8388608
MIN_IMAGE_WIDTH=900
MIN_IMAGE_HEIGHT=600
MIN_CAPTURE_QUALITY_SCORE=0.45
MAX_RETRY_COUNT=3
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/jpg

DEFAULT_OCR_ENGINE=paddleocr
REQUEST_TIMEOUT_SECONDS=30
