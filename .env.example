APP_NAME=FaceR Document Validation API
APP_VERSION=2.1.0
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
PORT=8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zona_franca_backend
DB_USER=root
DB_PASSWORD=change_me
DB_SOCKET_DIR=/cloudsql
CLOUD_SQL_CONNECTION_NAME=
# Ejemplo local con SQLite:
# DATABASE_URL=sqlite:///./data/facer_document_validation.db
DATABASE_URL=

# Opciones: local | gcs
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./data/storage
GCP_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_DOCUMENTS_PREFIX=documents

# Opciones: tesseract | google_vision
DEFAULT_OCR_ENGINE=tesseract
VISION_FEATURE_TYPE=DOCUMENT_TEXT_DETECTION
TESSERACT_LANGUAGES=spa+eng
TESSERACT_PAGE_SEGMENTATION_MODE=6
ENABLE_IMAGE_PREPROCESSING=true
AUTO_CREATE_DB_SCHEMA=true
REQUEST_TIMEOUT_SECONDS=30

MAX_UPLOAD_SIZE_BYTES=8388608
MIN_IMAGE_WIDTH=900
MIN_IMAGE_HEIGHT=600
MIN_CAPTURE_QUALITY_SCORE=0.45
MAX_RETRY_COUNT=3
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/jpg

# Authentication: set a strong random key for production.
# If empty, authentication is disabled (development mode only).
API_KEY=
