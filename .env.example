APP_NAME=FaceR Document Validation API
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
PORT=8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zona_franca_backend
DB_USER=root
DB_PASSWORD=change_me
DB_SOCKET_DIR=/cloudsql
CLOUD_SQL_CONNECTION_NAME=
DATABASE_URL=

GCP_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_DOCUMENTS_PREFIX=documents
VISION_FEATURE_TYPE=DOCUMENT_TEXT_DETECTION

MAX_UPLOAD_SIZE_BYTES=8388608
MIN_IMAGE_WIDTH=900
MIN_IMAGE_HEIGHT=600
MIN_CAPTURE_QUALITY_SCORE=0.45
MAX_RETRY_COUNT=3
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/jpg

DEFAULT_OCR_ENGINE=google_vision
REQUEST_TIMEOUT_SECONDS=30
